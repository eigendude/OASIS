#
# Generic identifiers for MCU-managed effects
#

# Unspecified effect kind
uint8 UNKNOWN=0

# Helipad guidance effect with IR sensing and paired LED outputs
uint8 HELIPAD=1

# Falcon LED thruster effect
uint8 LED_THRUSTER=2

# Reserved for future effect kinds
uint8 CUSTOM=255
